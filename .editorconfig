# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{cs,csproj,props,targets}]
indent_size = 4

[*.{json,yml,yaml}]
indent_size = 2

[*.{md,adoc}]
indent_size = 2
trim_trailing_whitespace = false  # trailing spaces are meaningful (hard line break)

[*.sh]
indent_size = 2

# C# conventions — the codebase builds with TreatWarningsAsErrors and nullable
# reference types enabled; keep new code warning-clean.
[*.cs]
dotnet_sort_system_directives_first = true
csharp_new_line_before_open_brace = all
csharp_indent_case_contents = true
csharp_prefer_braces = true:suggestion
dotnet_style_namespace_match_folder = true:suggestion
